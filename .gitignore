# ============================================================================
# .gitignore for Within Parameters (Vite + TypeScript Visual Novel)
# ============================================================================

# ----------------------------------------------------------------------------
# SECRETS & CREDENTIALS
# ----------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
secrets/
credentials/
config.local.*
*.secrets

# ----------------------------------------------------------------------------
# VAULT / AGENT WORKFLOW
# ----------------------------------------------------------------------------
*-pending.md
staging/
internal-files/
simulation/output/*.png
simulation/output/*.csv

# ----------------------------------------------------------------------------
# IDE & EDITOR
# ----------------------------------------------------------------------------
.vscode/
.idea/
.markdownlint.json
cspell.json
*.swp
*.swo
*~
.project

# ----------------------------------------------------------------------------
# NODE / VITE
# ----------------------------------------------------------------------------
node_modules/
dist/
package-lock.json

# ----------------------------------------------------------------------------
# TYPESCRIPT
# ----------------------------------------------------------------------------
*.tsbuildinfo

# ----------------------------------------------------------------------------
# BUILD & DOCUMENTATION
# ----------------------------------------------------------------------------
docs/_build/
site/
*.log
*.tmp
*.temp

# ----------------------------------------------------------------------------
# OS GENERATED
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----------------------------------------------------------------------------
# LARGE FILES
# ----------------------------------------------------------------------------
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.rar

# ----------------------------------------------------------------------------
# MISC
# ----------------------------------------------------------------------------
*.bak
*.backup
tmp/
temp/
scratch/
local/
.local/
*.local

.ruff_cache/
__pycache__/
